\name{student_summary}
\alias{student_summary}
\title{Create a Student Summary Object}
\usage{student_summary(x, na.rm = TRUE)}
\arguments{\item{x}{A numeric vector.}\item{na.rm}{Should missing values be removed?}}
\description{Calculates basic descriptive statistics and returns an S3 object.}
\examples{student_summary(c(88, 92, 75, 90, 84))}

\name{ci_mean}
\alias{ci_mean}
\title{Confidence Interval for a Mean}
\usage{ci_mean(x, conf_level = 0.95, na.rm = TRUE)}
\description{Calculates a t-based confidence interval for a sample mean.}
\examples{ci_mean(c(82, 90, 88, 76, 95))}

\name{t_test_helper}
\alias{t_test_helper}
\title{One-Sample T-Test Helper}
\usage{t_test_helper(x, mu = 0, alternative = "two.sided", conf_level = 0.95)}
\description{Runs a one-sample t-test and returns a simple table.}
\examples{t_test_helper(c(82, 90, 88, 76, 95), mu = 80)}

\name{grade_summary}
\alias{grade_summary}
\title{Summarize Student Grades}
\usage{grade_summary(scores)}
\description{Converts numeric grades into letter grades and summarizes the distribution.}
\examples{grade_summary(c(98, 87, 76, 91, 64, 82))}

\name{regression_helper}
\alias{regression_helper}
\title{Simple Regression Helper}
\usage{regression_helper(data, y, x)}
\description{Fits a simple linear regression model and returns important results.}
\examples{regression_helper(student_scores, y = "final_exam", x = "study_hours")}

\name{plot_distribution}
\alias{plot_distribution}
\title{Plot a Numeric Distribution}
\usage{plot_distribution(data, variable, bins = 10)}
\description{Creates a histogram with a density curve for a numeric variable.}
\examples{plot_distribution(student_scores, "final_exam")}
